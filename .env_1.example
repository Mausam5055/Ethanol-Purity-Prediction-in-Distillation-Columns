# ─────────────────────────────────────────────────────────────────────────────
# EthanolIQ · Environment Variables
# Copy this file to ".env" in the same folder as main.py
# Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Chatbot — Groq Cloud (Primary) ────────────────────────────────────────
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Available Groq Cloud models (pick one):
MODEL_NAME=llama3-70b-8192        # Recommended — fast, smart, free tier
# MODEL_NAME=llama3-8b-8192       # Faster / lighter
# MODEL_NAME=mixtral-8x7b-32768   # Larger context window
# MODEL_NAME=gemma2-9b-it         # Google Gemma 2

# ── Alternative: OpenAI ──────────────────────────────────────────────────────
# GROQ_API_KEY=sk-...
# GROQ_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini

# ── Alternative: Local Ollama ────────────────────────────────────────────────
# GROQ_API_KEY=ollama
# GROQ_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=llama3
