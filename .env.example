# ─────────────────────────────────────────────────────────────────────────────
# EthanolIQ · Environment Variables
# Copy this file to ".env" in the same folder as main.py
# Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Chatbot (Grok / OpenAI-compatible) ─────────────────────────────────
GROK_API_KEY=your_api_key_here
GROK_BASE_URL=https://api.x.ai/v1
MODEL_NAME=grok-beta

# ── Alternative: OpenAI ──────────────────────────────────────────────────
# GROK_API_KEY=sk-...
# GROK_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini

# ── Alternative: Local Ollama ────────────────────────────────────────────
# GROK_API_KEY=ollama
# GROK_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=llama3
